<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} | %-5level | %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/splitpay.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/splitpay.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} | %-5level | %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence everything by default -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- Only show HTTP transactions -->
    <logger name="splitpay.http" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Silence Exposed SQL completely -->
    <logger name="Exposed" level="OFF"/>
    <logger name="com.splitpay.database" level="OFF"/>

    <!-- Silence Ktor internals -->
    <logger name="io.ktor" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

</configuration>